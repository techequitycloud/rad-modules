{
  "name": "medusa-starter-default",
  "version": "0.0.1",
  "description": "A starter for Medusa projects",
  "author": "Medusa",
  "license": "MIT",
  "keywords": [
    "sqlite",
    "postgres",
    "typescript",
    "ecommerce",
    "headless",
    "medusa"
  ],
  "scripts": {
    "clean": "cross-env ./node_modules/.bin/rimraf dist",
    "build": "cross-env ./node_modules/.bin/rimraf dist && cross-env ./node_modules/.bin/tsc -p tsconfig.json",
    "watch": "cross-env ./node_modules/.bin/tsc --watch",
    "test": "cross-env ./node_modules/.bin/jest",
    "seed": "cross-env ./node_modules/.bin/medusa seed -f ./data/seed.json",
    "start": "cross-env ./node_modules/.bin/medusa start",
    "start:custom": "cross-env ./node_modules/.bin/medusa start",
    "dev": "cross-env ./node_modules/.bin/medusa develop"
  },
  "dependencies": {
    "@medusajs/medusa": "^1.20.0",
    "@medusajs/medusa-cli": "^1.3.21",
    "@medusajs/file-local": "^1.0.2",
    "medusa-plugin-file-cloud-storage": "^1.5.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.17.2",
    "medusa-interfaces": "^1.3.7",
    "medusa-fulfillment-manual": "^1.1.38",
    "medusa-payment-manual": "^1.0.24",
    "medusa-payment-stripe": "^6.0.7",
    "typeorm": "^0.3.16"
  },
  "devDependencies": {
    "@babel/cli": "^7.14.3",
    "@babel/core": "^7.14.3",
    "@babel/preset-typescript": "^7.21.4",
    "@types/express": "^4.17.13",
    "@types/jest": "^27.4.0",
    "@types/node": "^17.0.8",
    "babel-preset-medusa-package": "^1.1.19",
    "cross-env": "^7.0.3",
    "eslint": "^6.8.0",
    "jest": "^27.3.1",
    "rimraf": "^3.0.2",
    "ts-jest": "^27.0.7",
    "ts-loader": "^9.2.6",
    "typescript": "^4.5.2"
  }
}
