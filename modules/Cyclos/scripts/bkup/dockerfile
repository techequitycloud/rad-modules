FROM google/cloud-sdk:latest

# Install dependencies and database clients
RUN apt-get update && \
    apt-get install -y wget gnupg2 zip unzip tar gzip lsb-release

# Add PostgreSQL repository
RUN mkdir -p /etc/apt/keyrings && \
    wget --quiet -O - https://www.postgresql.org/media/keys/ACCC4CF8.asc | gpg --dearmor -o /etc/apt/keyrings/postgresql.gpg && \
    echo "deb [signed-by=/etc/apt/keyrings/postgresql.gpg] http://apt.postgresql.org/pub/repos/apt $(lsb_release -cs)-pgdg main" > /etc/apt/sources.list.d/pgdg.list

# Update and install packages (MySQL client from default repo)
RUN apt-get update && \
    apt-get install -y postgresql-client-16 default-mysql-client

# Copy the backup script
COPY backup.sh /usr/local/bin/backup.sh

# Ensure the backup script is executable
RUN chmod +x /usr/local/bin/backup.sh

# Set the default command to execute the backup script
CMD ["/usr/local/bin/backup.sh"]

